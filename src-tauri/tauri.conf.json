{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Furo",
  "version": "0.2.40",
  "identifier": "com.furo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Furo",
        "width": 1000,
        "height": 660,
        "minWidth": 1000,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "externalBin": [
      "binaries/whisper-server"
    ],
    "resources": [
      "binaries/*.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzMDhEQjA3NTU0QkI5OTkKUldTWnVVdFZCOXNJazZNb29udTYxUHl0UmRybzlUMkNOanZ4bENUWXNEbllPbDJmeGhVWXdDSVQK",
      "endpoints": [
        "https://github.com/AreKS103/Furo/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
